<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_green_gradient">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_activity"
            android:textColor="@color/rp_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Timeline -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvTimeline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textColor="@color/rp_neon_green"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Activity Item 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/activityCard1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTimeline">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivActivity1Icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Commit"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:tint="@color/rp_neon_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvActivity1Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Commit pushed to main"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity1Icon"
                        app:layout_constraintTop_toTopOf="@id/ivActivity1Icon" />

                    <TextView
                        android:id="@+id/tvActivity1Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Fix authentication bug in login flow"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity1Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity1Title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="6dp"
                        android:text="2 hours ago"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivActivity1Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity1Desc" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Activity Item 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/activityCard2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/activityCard1">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivActivity2Icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Pull Request"
                        android:src="@android:drawable/ic_menu_share"
                        android:tint="@color/rp_status_updated"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvActivity2Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Pull request merged"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity2Icon"
                        app:layout_constraintTop_toTopOf="@id/ivActivity2Icon" />

                    <TextView
                        android:id="@+id/tvActivity2Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Added dark mode support"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity2Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity2Title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="6dp"
                        android:text="5 hours ago"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivActivity2Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity2Desc" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Activity Item 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/activityCard3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/activityCard2">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivActivity3Icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Issue"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:tint="@color/rp_status_review"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvActivity3Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Issue opened"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity3Icon"
                        app:layout_constraintTop_toTopOf="@id/ivActivity3Icon" />

                    <TextView
                        android:id="@+id/tvActivity3Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Performance optimization needed"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity3Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity3Title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="6dp"
                        android:text="Yesterday"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivActivity3Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity3Desc" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Activity Item 4 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/activityCard4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/activityCard3">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivActivity4Icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Release"
                        android:src="@android:drawable/ic_menu_compass"
                        android:tint="@color/rp_status_healthy"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvActivity4Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Release v2.4.0 published"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity4Icon"
                        app:layout_constraintTop_toTopOf="@id/ivActivity4Icon" />

                    <TextView
                        android:id="@+id/tvActivity4Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Bug fixes and improvements"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivActivity4Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity4Title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="6dp"
                        android:text="3 days ago"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivActivity4Icon"
                        app:layout_constraintTop_toBottomOf="@id/tvActivity4Desc" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

