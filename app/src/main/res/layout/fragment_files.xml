<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_green_gradient"
    android:fitsSystemWindows="true">

    <!-- Top Bar removed - handled by HomeActivity toolbar -->

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/filesContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Total Changes Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/rp_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/rp_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTotalChangesTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/files_total_changes_title"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/files_total_changes_trend_desc"
                        android:src="@android:drawable/ic_menu_upload"
                        app:tint="@color/rp_neon_green"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTotalChangesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/files_total_changes_value"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTotalChangesTitle" />

                    <TextView
                        android:id="@+id/tvTotalChangesDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_badge_healthy"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/files_total_changes_delta"
                        android:textColor="@color/rp_status_healthy"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/tvTotalChangesValue"
                        app:layout_constraintStart_toEndOf="@id/tvTotalChangesValue" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Most Modified Files -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/files_most_modified_header"
                android:textColor="@color/rp_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/rp_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/rp_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:id="@+id/containerTopFiles">

                    <!-- index.js row -->
                    <LinearLayout
                        android:id="@+id/topFileRow1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/topFileName1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/files_index_js"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/topFileChanges1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/files_index_js_changes"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/topFileProgress1"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:progress="100"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_file_progress"
                        android:background="@drawable/bg_file_progress_track" />

                    <!-- auth_service.py row -->
                    <LinearLayout
                        android:id="@+id/topFileRow2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/topFileName2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/files_auth_service"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/topFileChanges2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/files_auth_service_changes"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/topFileProgress2"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:progress="72"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_file_progress"
                        android:background="@drawable/bg_file_progress_track" />

                    <!-- dashboard_v2.tsx row -->
                    <LinearLayout
                        android:id="@+id/topFileRow3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/topFileName3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/files_dashboard_v2"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/topFileChanges3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/files_dashboard_v2_changes"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/topFileProgress3"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:progress="40"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_file_progress"
                        android:background="@drawable/bg_file_progress_track" />

                    <!-- CHANGELOG.md row -->
                    <LinearLayout
                        android:id="@+id/topFileRow4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/topFileName4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/files_changelog_md"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/topFileChanges4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/files_changelog_md_changes"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/topFileProgress4"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:progress="28"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_file_progress"
                        android:background="@drawable/bg_file_progress_track" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Updates header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/files_recent_updates"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/files_view_all"
                    android:textColor="@color/rp_neon_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Recent files RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/enter_git_url_to_analyze"
        android:textColor="@color/rp_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

