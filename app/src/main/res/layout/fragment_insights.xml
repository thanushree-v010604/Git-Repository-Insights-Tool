<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_green_gradient"
    android:fitsSystemWindows="true">

    <!-- ── TOP APP BAR ─────────────────────────────────────── -->

    <!-- ── SCROLLABLE CONTENT ──────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/insightsContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="100dp">

            <!-- New placement for total commits (moved out of removed card so code keeps working) -->

            <!-- Impact Distribution Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardImpactDistribution"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvImpactTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_impact_distribution"
                        android:textColor="@color/rp_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/impactBar"
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvImpactTitle">

                        <View
                            android:id="@+id/coreSegment"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/rp_text_primary" />

                        <View
                            android:id="@+id/uiSegment"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/rp_text_primary" />

                        <View
                            android:id="@+id/apiSegment"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/rp_text_primary" />

                        <View
                            android:id="@+id/docsSegment"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/rp_text_primary" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Language Breakdown Section -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/donutChart"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardImpactDistribution" />

            <!-- Percentage Texts -->
            <LinearLayout
                android:id="@+id/percentageContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/donutChart">

                <TextView
                    android:id="@+id/corePercent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/insights_percent_placeholder"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/uiPercent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/insights_percent_placeholder"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/apiPercent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/insights_percent_placeholder"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/docsPercent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/insights_percent_placeholder"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ── SECTION 2 : Two stat cards side-by-side ─ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/statsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/percentageContainer">

                <!-- Weekly Growth -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWeeklyGrowth"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/rp_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:layout_constraintEnd_toStartOf="@id/cardReviewSpeed"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvGrowthTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_weekly_growth"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toStartOf="@id/ivTrendUp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivTrendUp"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/insights_trend_up"
                            android:src="@android:drawable/ic_menu_upload"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/rp_neon_green" />

                        <!-- Rename value id to match InsightsFragment -->
                        <TextView
                            android:id="@+id/tvWeeklyGrowth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_weekly_growth_placeholder"
                            android:textColor="@color/rp_neon_green"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvGrowthTitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <!-- Review Speed -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReviewSpeed"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/rp_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/cardWeeklyGrowth"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvReviewSpeedTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_review_speed"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvReviewSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_review_speed_placeholder"
                            android:textColor="@color/rp_neon_green"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvReviewSpeedTitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── SECTION 3 : Top Contributors header ─────── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/contributorsHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsRow">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_top_contributors"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_view_all"
                    android:textColor="@color/rp_neon_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Contributor RecyclerView ────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContributors"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/contributorsHeader" />

            <!-- AI-based Repository Health section (backend-driven) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRepoHealth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvContributors">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvHealthTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_health_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/healthText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/insights_health_placeholder"
                        android:textColor="@color/rp_neon_green"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/tvHealthTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvHealthTitle" />

                    <TextView
                        android:id="@+id/tvRisksTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/insights_risks_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/healthText" />

                    <TextView
                        android:id="@+id/risksText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/insights_risks_placeholder"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/tvRisksTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvRisksTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvSuggestionsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/insights_suggestions_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/risksText" />

                    <TextView
                        android:id="@+id/suggestionsText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/insights_suggestions_placeholder"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/tvSuggestionsTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvSuggestionsTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/enter_git_url_to_analyze"
        android:textColor="@color/rp_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

