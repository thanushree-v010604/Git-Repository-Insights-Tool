<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_green_gradient"
    android:fitsSystemWindows="true">

    <!-- ── TOP APP BAR ─────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/insights_back"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/rp_text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_title"
            android:textColor="@color/rp_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivShareIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/insights_share"
            android:src="@android:drawable/ic_menu_share"
            app:tint="@color/rp_text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── SCROLLABLE CONTENT ──────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="100dp">

            <!-- ── SECTION 1 : Impact Distribution Card ──── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardImpactDistribution"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Card title -->
                    <TextView
                        android:id="@+id/tvImpactTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_impact_distribution"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Donut chart -->
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/donutChart"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginTop="16dp"
                        app:layout_constraintEnd_toStartOf="@id/llLegend"
                        app:layout_constraintHorizontal_bias="0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvImpactTitle" />

                    <!-- Center overlay text for donut -->
                    <LinearLayout
                        android:id="@+id/donutCenterText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="@id/donutChart"
                        app:layout_constraintEnd_toEndOf="@id/donutChart"
                        app:layout_constraintStart_toStartOf="@id/donutChart"
                        app:layout_constraintTop_toTopOf="@id/donutChart">

                        <TextView
                            android:id="@+id/tvTotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_total_value"
                            android:textColor="@color/rp_neon_green"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Legend (right side) -->
                    <LinearLayout
                        android:id="@+id/llLegend"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/donutChart"
                        app:layout_constraintTop_toBottomOf="@id/tvImpactTitle">

                        <!-- Core -->
                        <TextView
                            android:id="@+id/corePercent"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@string/legend_core"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="12sp"
                            app:drawableStartCompat="@drawable/dot_core" />

                        <!-- UI/UX -->
                        <TextView
                            android:id="@+id/uiPercent"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@string/legend_ui"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="12sp"
                            app:drawableStartCompat="@drawable/dot_core" />

                        <!-- API -->
                        <TextView
                            android:id="@+id/apiPercent"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@string/legend_api"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="12sp"
                            app:drawableStartCompat="@drawable/dot_api" />

                        <!-- Docs -->
                        <TextView
                            android:id="@+id/docsPercent"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@string/legend_docs"
                            android:textColor="@color/rp_text_primary"
                            android:textSize="12sp"
                            app:drawableStartCompat="@drawable/dot_docs" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTotalLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_total_label"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintTop_toBottomOf="@id/donutCenterText"
                        app:layout_constraintStart_toStartOf="@id/donutCenterText" />

                    <!-- New total commits value under the center text -->
                    <TextView
                        android:id="@+id/tvTotalCommits"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_total_commits_placeholder"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/tvTotalLabel"
                        app:layout_constraintStart_toStartOf="@id/tvTotalLabel" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── SECTION 2 : Two stat cards side-by-side ─ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/statsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardImpactDistribution">

                <!-- Weekly Growth -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWeeklyGrowth"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/rp_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:layout_constraintEnd_toStartOf="@id/cardReviewSpeed"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvGrowthTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_weekly_growth"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toStartOf="@id/ivTrendUp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivTrendUp"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/insights_trend_up"
                            android:src="@android:drawable/ic_menu_upload"
                            app:tint="@color/rp_neon_green"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Rename value id to match InsightsFragment -->
                        <TextView
                            android:id="@+id/tvWeeklyGrowth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_weekly_growth_placeholder"
                            android:textColor="@color/rp_neon_green"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvGrowthTitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <!-- Review Speed -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReviewSpeed"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/rp_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/cardWeeklyGrowth"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvSpeedTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_review_speed"
                            android:textColor="@color/rp_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toStartOf="@id/ivLightning"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivLightning"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/insights_lightning"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="@color/rp_neon_green"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Rename value id to match InsightsFragment -->
                        <TextView
                            android:id="@+id/tvReviewSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/insights_review_speed_placeholder"
                            android:textColor="@color/rp_neon_green"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvSpeedTitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── SECTION 3 : Top Contributors header ─────── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/contributorsHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsRow">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_top_contributors"
                    android:textColor="@color/rp_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_view_all"
                    android:textColor="@color/rp_neon_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Contributor RecyclerView ────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContributors"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/contributorsHeader" />

            <!-- AI-based Repository Health section (backend-driven) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRepoHealth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/rp_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvContributors">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvHealthTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_health_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/healthText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/insights_health_placeholder"
                        android:textColor="@color/rp_neon_green"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/tvHealthTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvHealthTitle" />

                    <TextView
                        android:id="@+id/tvRisksTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/insights_risks_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/healthText" />

                    <TextView
                        android:id="@+id/risksText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/insights_risks_placeholder"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/tvRisksTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvRisksTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvSuggestionsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/insights_suggestions_title"
                        android:textColor="@color/rp_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/risksText" />

                    <TextView
                        android:id="@+id/suggestionsText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/insights_suggestions_placeholder"
                        android:textColor="@color/rp_text_muted"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/tvSuggestionsTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvSuggestionsTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

