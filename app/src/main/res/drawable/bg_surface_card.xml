<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/rp_glass_overlay" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="@color/rp_glass_tint" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/rp_surface" />
            <corners android:radius="23dp" />
            <stroke android:width="1dp" android:color="@color/rp_shadow_green" />
        </shape>
    </item>
</layer-list>
