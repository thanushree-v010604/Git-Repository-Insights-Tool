<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/rp_progress_track" />
            <corners android:radius="50dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="50dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="120dp"
                        android:centerX="50%"
                        android:centerY="50%"
                        android:startColor="@color/rp_border"
                        android:endColor="@android:color/transparent" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/rp_neon_green" />
                    <stroke android:width="1dp" android:color="@color/rp_status_healthy" />
                    <corners android:radius="50dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
